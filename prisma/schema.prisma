generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      Role      @default(USER)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  ADMIN
  USER
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]
  events      Event[]
  items       Item[]
  user        User?    @relation(fields: [userId], references: [id])
  rooms       Room[]

  @@index([userId], map: "Project_userId_fkey")
}

model Room {
  id        String    @id @default(cuid())
  projectId String
  name      String
  bgImageId String?
  events    Event[]
  exits     Exit[]
  hotspots  Hotspot[]
  bgImage   Asset?    @relation(fields: [bgImageId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprites   Sprite[]

  @@index([bgImageId], map: "Room_bgImageId_fkey")
  @@index([projectId], map: "Room_projectId_fkey")
}

model Sprite {
  id          String  @id @default(cuid())
  roomId      String
  assetId     String
  name        String
  x           Float
  y           Float
  width       Float
  height      Float
  objectId    String?
  description String?
  zIndex      Int     @default(0)
  visible     Boolean @default(true)
  asset       Asset   @relation(fields: [assetId], references: [id])
  room        Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([assetId], map: "Sprite_assetId_fkey")
  @@index([roomId], map: "Sprite_roomId_fkey")
}

model Hotspot {
  id          String  @id @default(cuid())
  roomId      String
  name        String
  x           Float
  y           Float
  width       Float
  height      Float
  objectId    String?
  action      String?
  description String?
  visible     Boolean @default(true)
  room        Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId], map: "Hotspot_roomId_fkey")
}

model Exit {
  id         String @id @default(cuid())
  fromRoomId String
  toRoomId   String
  direction  String
  fromRoom   Room   @relation(fields: [fromRoomId], references: [id], onDelete: Cascade)

  @@index([fromRoomId], map: "Exit_fromRoomId_fkey")
}

model Item {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String?
  iconId      String?
  icon        Asset?  @relation(fields: [iconId], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([iconId], map: "Item_iconId_fkey")
  @@index([projectId], map: "Item_projectId_fkey")
}

model Asset {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String
  url       String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items     Item[]
  rooms     Room[]
  sprites   Sprite[]

  @@index([projectId], map: "Asset_projectId_fkey")
}

model Event {
  id         String           @id @default(cuid())
  projectId  String
  name       String
  action     String
  targetId   String?
  roomId     String?
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room       Room?            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  conditions EventCondition[]
  results    EventResult[]

  @@index([projectId], map: "Event_projectId_fkey")
  @@index([roomId], map: "Event_roomId_fkey")
}

model EventCondition {
  id       String  @id @default(cuid())
  eventId  String
  type     String
  targetId String?
  value    String?
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId], map: "EventCondition_eventId_fkey")
}

model EventResult {
  id       String  @id @default(cuid())
  eventId  String
  type     String
  targetId String?
  value    String?
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId], map: "EventResult_eventId_fkey")
}

model GlobalSettings {
  id                 String  @id @default("default")
  maintenanceMode    Boolean @default(false)
  maintenanceMessage String? @db.Text
}
